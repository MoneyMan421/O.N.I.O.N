# AZ123ONI/.env.example
#
# Example configuration for O.N.I.O.N Azure deployment.
# Copy this file to `.env` and fill in your real secrets for development or deployment.

# Azure Agent and Environment
AZURE_EXISTING_AGENT_ID="your-agent-id"
AZURE_ENV_NAME="your-env-name"
AZURE_LOCATION="eastus2"
AZURE_SUBSCRIPTION_ID="your-azure-subscription-guid"

# Azure AI Project & Resource Details
AZURE_EXISTING_AIPROJECT_ENDPOINT="https://your-resource-url/api/projects/your-project"
AZURE_EXISTING_AIPROJECT_RESOURCE_ID="/subscriptions/your-guid/resourceGroups/your-rg/providers/Microsoft.CognitiveServices/accounts/your-resource-account"
AZURE_EXISTING_RESOURCE_ID="/subscriptions/your-guid/resourceGroups/your-rg/providers/Microsoft.CognitiveServices/accounts/your-resource-account"

# (Optional) Allow non-empty deployments/folder
AZD_ALLOW_NON_EMPTY_FOLDER=true

# ---
# NEVER commit your real .env to VCS. Only share `.env.example` as a template.
