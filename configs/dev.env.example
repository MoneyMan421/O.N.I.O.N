# Environment: Development

# Services
NODE_ENV=development
PORT=8080

# API Gateway
API_GATEWAY_PORT=8080
PDP_SERVICE_URL=http://localhost:8081
AUDIT_SERVICE_URL=http://localhost:8084

# Policy PDP
PDP_PORT=8081
POLICY_CONFIG_PATH=./configs/policy-config.yaml

# Approval Service
APPROVAL_PORT=8082
NOTIFICATION_SERVICE_URL=http://localhost:8083

# Notification Service
NOTIFICATION_PORT=8083
SMTP_HOST=localhost
SMTP_PORT=1025

# Audit Service
AUDIT_PORT=8084
AUDIT_DATABASE_URL=postgresql://localhost:5432/onion_audit_dev

# Telemetry Ingest
TELEMETRY_PORT=8085

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Security (DO NOT COMMIT REAL SECRETS)
JWT_SECRET=dev-secret-change-in-production
ENCRYPTION_KEY=dev-encryption-key-32-chars!!

# Azure (Development)
AZURE_TENANT_ID=your-tenant-id
AZURE_SUBSCRIPTION_ID=your-subscription-id
